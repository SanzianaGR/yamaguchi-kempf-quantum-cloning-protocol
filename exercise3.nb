Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"exercise", " ", "3"}], ":", " ", 
     RowBox[{
      RowBox[{"verification", " ", "of", " ", "Yamaguchi"}], "-", 
      RowBox[{"Kempf", " ", "protocol"}]}]}], ",", " ", 
    RowBox[{
    "proving", " ", "S1", " ", "disentanglement", " ", "and", " ", "pure", " ",
      "state", " ", "A", " ", "recovery"}]}], " ", "*)"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"psiT", "=", 
     RowBox[{"ArrayReshape", "[", 
      RowBox[{
       RowBox[{"Flatten", "[", "state6", "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"2", ",", "2", ",", "2", ",", "2", ",", "2"}], "}"}]}], 
      "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"rhoS1", "=", 
     RowBox[{
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"Sum", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"psiT", "[", 
            RowBox[{"[", 
             RowBox[{"n", ",", "i", ",", "s", ",", "m", ",", "k"}], "]"}], 
            "]"}], " ", 
           RowBox[{"Conjugate", "[", 
            RowBox[{"psiT", "[", 
             RowBox[{"[", 
              RowBox[{"n", ",", "j", ",", "s", ",", "m", ",", "k"}], "]"}], 
             "]"}], "]"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"n", ",", "2"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"s", ",", "2"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"m", ",", "2"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"k", ",", "2"}], "}"}]}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "2"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"j", ",", "2"}], "}"}]}], "]"}], "//", "FullSimplify"}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"rhoTarget", "=", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", "a", "}"}], ",", 
        RowBox[{"{", "b", "}"}]}], "}"}], ".", 
      RowBox[{"{", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Conjugate", "[", "a", "]"}], ",", 
         RowBox[{"Conjugate", "[", "b", "]"}]}], "}"}], "}"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"traceRhoSq", "=", 
     RowBox[{
      RowBox[{"Tr", "[", 
       RowBox[{"rhoS1", ".", "rhoS1"}], "]"}], "/.", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"a", "*", "b", "*", 
         RowBox[{"Conjugate", "[", "a", "]"}], "*", 
         RowBox[{"Conjugate", "[", "b", "]"}]}], "->", 
        RowBox[{
         RowBox[{
          RowBox[{"Abs", "[", "a", "]"}], "^", "2"}], "*", 
         RowBox[{
          RowBox[{"Abs", "[", "b", "]"}], "^", "2"}]}]}], "}"}]}]}], ";"}], 
   "\n", "\[IndentingNewLine]", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<Tr[rho_{S1}^2] == 1:\>\"", ",", 
     RowBox[{"Simplify", "[", 
      RowBox[{
       RowBox[{"traceRhoSq", "==", "1"}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"Abs", "[", "a", "]"}], "^", "2"}], "+", 
         RowBox[{
          RowBox[{"Abs", "[", "b", "]"}], "^", "2"}]}], "==", "1"}]}], 
      "]"}]}], "]"}], "\n"}]}]], "Input",
